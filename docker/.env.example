# Sequencer compose stack — developer inputs only.
# Generated values (keys, pubkeys, ports) live in configs/generated/.env.alpen
#
# Copy to .env and edit as needed:
#   cp .env.example .env

# --- used by: gen-params-and-elfs.sh, init-network.sh, strata ---
BITCOIN_NETWORK=signet
BITCOIND_RPC_URL=http://bitcoind:38332
BITCOIND_RPC_USER=bitcoin
BITCOIND_RPC_PASSWORD=bitcoin
GENESIS_L1_HEIGHT=20
OUTPUT_DIR=./configs/generated
ENV_FILE=./configs/generated/.env.alpen

# --- used by: compose-signet.yml ---
MNEMONIC=
MINERENABLED=1
MINE_GENESIS=1
BLOCKPRODUCTIONDELAY=2

# --- used by: all ---
RUST_LOG=info

# --- Uncomment for real SP1 proofs ---
# CHECKPOINT_PREDICATE=sp1-groth16
# ALPEN_PREDICATE=sp1-groth16
# STRATA_CARGO_FEATURES=prover,sp1
# DATATOOL_CARGO_FEATURES=sp1-docker-builder
# SP1_PROVER=network
# SP1_PROOF_STRATEGY=reserved
# NETWORK_PRIVATE_KEY=0x...
# NETWORK_RPC_URL=https://rpc.production.succinct.xyz
