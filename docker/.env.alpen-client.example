# .env.alpen-client.example
#
# Copy to .env.alpen-client, then run ./init-alpen-client-keys.sh to populate
# cryptographic values (keys).
#
# [GENERATED] = computed by init-alpen-client-keys.sh
# [CONFIGURABLE] = operator tunable

# --- Sequencer Schnorr keys (gossip signing) --------------------------------
# [GENERATED]
SEQUENCER_PRIVATE_KEY=
SEQUENCER_PUBKEY=

# --- Chain spec -------------------------------------------------------------
# [CONFIGURABLE] dev | devnet | testnet (or path to custom chain spec)
CHAIN_SPEC=testnet

# --- Bitcoin RPC -------------------------------------------------------------
# [CONFIGURABLE]
BITCOIND_RPC_USER=rpcuser
BITCOIND_RPC_PASSWORD=rpcpassword
BITCOIND_RPC_PORT=18443

# --- OL (strata) -------------------------------------------------------------
STRATA_RPC_PORT=8432

# --- Port overrides ----------------------------------------------------------
# [CONFIGURABLE] Host ports for each service
HTTP_PORT=8545
WS_PORT=8546
P2P_PORT=30303

# --- Logging -----------------------------------------------------------------
# [CONFIGURABLE] info | debug | trace | info,alpen_gossip=debug
RUST_LOG=info
